{
  "name": "@giwater/shared",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./nest/swagger": {
      "types": "./dist/nest/swagger.d.ts",
      "import": "./dist/nest/swagger.js",
      "require": "./dist/nest/swagger.cjs"
    },
    "./constants": {
      "types": "./dist/entries/constants.d.ts",
      "import": "./dist/entries/constants.js",
      "require": "./dist/entries/constants.cjs"
    },
    "./abis": {
      "types": "./dist/entries/abis.d.ts",
      "import": "./dist/entries/abis.js",
      "require": "./dist/entries/abis.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run"
  },
  "dependencies": {
    "@nestjs/swagger": "^11.2.5",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8"
  }
}
