PORT=3045

# When using external cron (e.g. Railway Cron every minute), set true on the long-running
# broker process so @Cron does not double-run the same OHLCV bucket advance.
# DISABLE_BROKER_OHLCV_CRON=true

# Swap OHLCV finest bucket (`1m` stream grid width). Default in code is 60 if unset.
# Recommended when minimum cron is 5 minutes (e.g. Railway): cron `*/5 * * * *` (UTC) and:
SWAP_BUCKET_FINEST_PERIOD_SEC=300
# Local dev with every-minute cron: omit this or use 60.
#
# CAUTION: If `1m` data was already written on a 60s grid, switching to 300 changes bucket
# boundaries — do not mix without migration/reprocessing. Set once on a fresh env or initial deploy.

# Broker DB (OHLCV + derived trading data)
# Prefer one of these:
BROKER_DATABASE_URL=postgres://postgres:postgres@localhost:5432/giwater_broker
# (Accepted fallback) BROKDER_DATABASE_URL=postgres://...

# RabbitMQ (amqp-connection-manager)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Queue consumed from amm-indexer (producer must publish here or bind exchange → queue)
RABBITMQ_INDEXER_QUEUE=amm-indexer.events

# Topic exchange: gateway replicas bind their queues with routing keys
RABBITMQ_GATEWAY_EXCHANGE=giwater.gateway

# Gateway → broker RPC (client sets replyTo + correlationId)
RABBITMQ_BROKER_RPC_QUEUE=broker.rpc

# Routing key when forwarding indexer payloads to the gateway exchange
RABBITMQ_GATEWAY_INDEXER_ROUTING_KEY=indexer.event

# USD routing hints for TVL / token USD (`DexUsdQuoteService`)
DEX_USD_QUOTE_USDT=
DEX_USD_QUOTE_WETH=

# UI BASE/QUOTE inference (`inferDisplayBaseQuote`): comma-separated stable addresses treated as QUOTE when paired with a non-stable (merged with DEX_USD_QUOTE_USDT). Optional WETH-as-quote when no stable: DEX_PAIR_DISPLAY_NATIVE_AS_QUOTE=true (default).
DEX_PAIR_DISPLAY_STABLES=
# DEX_PAIR_DISPLAY_NATIVE_AS_QUOTE=false