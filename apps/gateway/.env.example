PORT=3046

# Redis — HTTP response cache (and optional future Socket.IO adapter)
REDIS_URL=redis://127.0.0.1:6379
REDIS_KEY_PREFIX=gateway:http:
# Fresh window (seconds); after that responses may still be served as STALE until fresh+stale elapses.
REDIS_HTTP_CACHE_TTL_SEC=3
REDIS_HTTP_CACHE_STALE_EXTRA_TTL_SEC=60
# Comma-separated `req.originalUrl` prefixes to skip (default in code: /api/health,/api/docs)
# REDIS_HTTP_CACHE_EXCLUDE_URL_PREFIXES=/api/health,/api/docs

# RabbitMQ — must match apps/broker (.env)
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_BROKER_RPC_QUEUE=broker.rpc
RABBITMQ_GATEWAY_EXCHANGE=giwater.gateway
# Topic binding for broker → gateway fan-out (each replica auto-creates its own ephemeral queue)
RABBITMQ_GATEWAY_BINDING_KEY=#
RABBITMQ_RPC_TIMEOUT_MS=15000
