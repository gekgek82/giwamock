# Required
PRIVATE_KEY=0x...          # Bot wallet private key (testnet only — never use a funded mainnet wallet)
TOKEN0=0x...               # Address of the first token
TOKEN1=0x...               # Address of the second token
RPC_URL=https://...        # Giwa Sepolia RPC endpoint

# Optional
SWAP_AMOUNT=1.0            # Amount to swap per cycle (in human-readable token units)
SWAP_INTERVAL_MS=2000      # Interval between swaps in milliseconds (default: 2000, min: 500)
STABLE=false               # true = stable pool, false = volatile pool (default: false)
SLIPPAGE_BPS=50            # Slippage tolerance in basis points (default: 50 = 0.5%)
MAX_CONSECUTIVE_ERRORS=5   # Circuit breaker threshold (default: 5)

# Telegram (optional — omit to disable)
TG_BOT_TOKEN=              # BotFather token (e.g. 123456:ABC-DEF...)
