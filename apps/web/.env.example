# GiwaTer App Environment Variables
# Copy this file to .env.local and fill in your values

# =============================================================================
# Blockchain Configuration
# =============================================================================

# WalletConnect Project ID (get one at https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# =============================================================================
# GiWater Gateway (HTTP + Socket.IO)
# =============================================================================

# Gateway edge URL (Nest on port 3046 by default). Same host as indexer API in production when both are exposed via gateway.
# Production: https://gateway.giwater.finance
# Development: http://localhost:3046
#
# Pool picker on user flows (e.g. deposit, liquidity): broker `spot_pairs` via same-origin `/api/gateway/*` (proxies here).
# Must be set for curated pool lists; indexer `GET /pools/stats` is not used for that list.
NEXT_PUBLIC_GATEWAY_URL=http://localhost:3046

# =============================================================================
# AMM Indexer (Ponder) — server-only; used by `/api/admin/indexer/*` proxy
# =============================================================================
#
# Internal URL of the running Ponder amm-indexer service (Railway or local).
# NOT NEXT_PUBLIC — never exposed to the browser.
# Development: http://localhost:42069 (Ponder's default port)
# Production: set to the Railway internal URL of the amm-indexer service
#
INDEXER_INTERNAL_URL=http://localhost:42069

# =============================================================================
# Admin API (server-only; proxied via Next.js `/api/admin/*`)
# =============================================================================
#
# IMPORTANT:
# - Do NOT prefix with NEXT_PUBLIC_ (must remain server-only).
# - Browser calls `http://localhost:3007/api/admin/...` and Next.js proxies to this upstream.
#
ADMIN_API_URL=https://admin.giwater.finance

# =============================================================================
# Broker Admin (server-only; proxied via Next.js `/api/broker-admin/*`)
# =============================================================================
#
# Used by `/admin/*` UI flows for curation actions (e.g. spot-token-groups membership).
#
BROKER_ADMIN_URL=https://admin.giwater.finance

# =============================================================================
# Config Service Admin (server-only; proxied via Next.js `/api/config-admin/*`)
# =============================================================================
#
# Used by `/admin/*` UI flows for config actions (e.g. watched-wallets, token-faucets).
#
CONFIG_ADMIN_URL=http://localhost:3047

# Chain Configuration
NEXT_PUBLIC_GIWASCAN_URL=https://sepolia-explorer.giwa.io
NEXT_PUBLIC_GIWA_SEPOLIA_CHAIN_ID=91342

# =============================================================================
# Admin Authentication (server-only; never expose to browser)
# =============================================================================
#
# Password for the /admin UI login form. Validated server-side via POST /api/admin/auth.
# Do NOT prefix with NEXT_PUBLIC_ — this must stay out of the client JS bundle.
#
ADMIN_PASSWORD=change-me-before-deploying

# =============================================================================
# Site Password Protection (server-only; never expose to browser)
# =============================================================================
#
# Password for the global site-wide PasswordProtection gate. Validated server-side
# via POST /api/auth/site. Do NOT prefix with NEXT_PUBLIC_ — this must stay out
# of the client JS bundle.
#
SITE_PASSWORD=change-me-before-deploying

# =============================================================================
# Feature Flags
# =============================================================================

# Pre-TGE mode: use offchain tPOINT locking (set to "false" or remove after TGE)
NEXT_PUBLIC_PRE_TGE=true

# Mock data: when "true", `apiFetch` (in `lib/apiClient.ts`) short-circuits
# every API call and returns canned responses from `lib/mocks.ts`. Used to
# preview designs without a running gateway/broker. Unmatched requests fall
# through to a real fetch (which will likely fail offline) and log a warning.
NEXT_PUBLIC_MOCK_DATA=false
