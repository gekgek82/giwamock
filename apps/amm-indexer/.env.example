PONDER_RPC_URL_1=
PONDER_RPC_MAX_RPS=10
DATABASE_URL=
INDEXER_DATABASE_SCHEMA_NAME=amm_indexer

# RabbitMQ → broker ingest
RABBITMQ_ENABLED=false
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_INDEXER_QUEUE=amm-indexer.events

# Pair price display rules at pool creation (`inferIndexerPairPriceOrientation`).
# Defaults: `DEFAULT_GIWA_STABLE_QUOTE_ADDRESSES` + `PAIR_INDEXER_NETWORK_QUOTE_TOKEN_WGIWA` from `@giwater/shared`
# (`config/stable-quote-addresses`, `constants/pair-indexer-display`). Set only to override.
INDEXER_PAIR_STABLE_ADDRESSES=
INDEXER_PAIR_NETWORK_QUOTE_TOKEN=

